<UserControl x:Class="UNACH.Alumnos.WPF.Capa_presentacion.AgregarAlumnoUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UNACH.Alumnos.WPF.Capa_presentacion"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Border Background="White"
                CornerRadius="16"
                Margin="40"
                Padding="40">
            <Border.Effect>
                <DropShadowEffect Color="#000000" 
                                Opacity="0.08" 
                                BlurRadius="30" 
                                ShadowDepth="0"
                                Direction="0"/>
            </Border.Effect>

            <StackPanel>
                <!-- Encabezado -->
                <StackPanel Margin="0,0,0,30">
                    <TextBlock Text="Agregar Nuevo Alumno"
                             FontFamily="Segoe UI Light"
                             FontSize="28"
                             Foreground="#2D3436"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="Complete los datos del estudiante"
                             FontFamily="Segoe UI"
                             FontSize="14"
                             Foreground="#636E72"/>
                </StackPanel>

                <!-- Formulario -->
                <StackPanel Margin="0,0,0,30">
                    <!-- Campo Nombre -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Nombre completo *"
                                 Style="{StaticResource ModernLabel}"/>
                        <TextBox x:Name="txtNombre"
                               Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <!-- Campo Teléfono -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Teléfono *"
                                 Style="{StaticResource ModernLabel}"/>
                        <TextBox x:Name="txtTelefono"
                               Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <!-- Campo Correo -->
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Correo electrónico *"
                                 Style="{StaticResource ModernLabel}"/>
                        <TextBox x:Name="txtCorreo"
                               Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Botones de acción -->
                <Grid Margin="0,10,0,0" Height="26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnCancelar"
                          Content="Cancelar"
                          Style="{StaticResource SecondaryButton}"
                          Grid.Column="1"
                          Margin="0,0,12,-11"
                          Width="120"/>

                    <Button x:Name="btnGuardar"
                          Content="Guardar Alumno"
                          Style="{StaticResource PrimaryButton}"
                          Grid.Column="2"
                          Width="150" Margin="0,0,0,-11"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
