<UserControl x:Class="UNACH.Alumnos.WPF.Capa_presentacion.MaestrosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UNACH.Alumnos.WPF.Capa_presentacion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Profesores" FontSize="40"></TextBlock>
        <DataGrid Grid.Row="2" x:Name="MaestrosDG" AutoGenerateColumns="True" Margin="10"/>
    </Grid>
</UserControl>
