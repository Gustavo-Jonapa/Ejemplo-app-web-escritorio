<Window x:Class="UNACH.Alumnos.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UNACH.Alumnos.WPF"
        mc:Ignorable="d"
        Title="ADMIN" Height="450" Width="800" WindowState="Maximized">
    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="{DynamicResource ColorFondo}"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.Background>
                <SolidColorBrush Color="{DynamicResource ColorBarra}"/>
            </Grid.Background>
            <TextBlock Text="Control de alumnos" Foreground="White" 
                       FontSize="40" TextAlignment="Center" Margin="0,10,0,20"/>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel.Background>
                    <SolidColorBrush Color="{DynamicResource ColorMenu}"/>
                </StackPanel.Background>
                <Button Content="Alumnos" Height="60" Margin="3.5" x:Name="AlumnosButtom" Click="AlumnosButtom_Click"></Button>
                <Button Content="Acerca de" Height="60" Margin="3.5" x:Name="AcercaButtom" Click="AcercaButtom_Click"></Button>
            </StackPanel>
            <Grid Grid.Column="1" x:Name="ContenedorGrid">
                
            </Grid>
        </Grid>
    </Grid>
</Window>
