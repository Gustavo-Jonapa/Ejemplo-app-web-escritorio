@model UNACH.Alumnos.Sitio100019241.Models.Alumno

@{
    ViewBag.Title = "Detalle Alumno";
}

<div class="container" style="padding: 30px 15px;">
    <ol class="breadcrumb"
        style="background:#e8eaf6; border-radius:6px; padding:10px 18px;
               margin-bottom:24px; font-size:13px;">
        <li class="active" style="color:#555;">Detalle del Alumno</li>
    </ol>

    <div class="row">
        <div class="col-md-8 col-md-offset-2">

            <div style="background:#fff; border-radius:10px;
                        box-shadow:0 2px 20px rgba(0,0,0,0.1); overflow:hidden;">
                <div style="background: linear-gradient(135deg, #1a237e 0%, #3949ab 100%);
                             padding: 28px; text-align:center;">
                    <div style="width:80px; height:80px; background:rgba(255,255,255,0.2);
                                border-radius:50%; margin:0 auto 14px;
                                display:flex; align-items:center; justify-content:center;
                                border:3px solid rgba(255,255,255,0.5);">
                        <span class="glyphicon glyphicon-user"
                              style="font-size:36px; color:#fff;"></span>
                    </div>
                    <h3 style="color:#fff; margin:0; font-weight:700;">@Model.Nombre</h3>
                    <p style="color:rgba(255,255,255,0.7); margin:6px 0 0; font-size:13px;">
                        ID: #@Model.id
                    </p>
                </div>

                <div style="padding:28px 32px;">

                    <div style="display:flex; align-items:center; padding:16px 0;
                                 border-bottom:1px solid #f0f0f0;">
                        <div style="width:44px; height:44px; background:#e8eaf6; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-user" style="color:#3949ab; font-size:18px;"></span>
                        </div>
                        <div style="margin-left:16px;">
                            <div style="color:#9e9e9e; font-size:12px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.Nombre)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:500; margin-top:2px;">
                                @Html.DisplayFor(model => model.Nombre)
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; align-items:center; padding:16px 0;
                                 border-bottom:1px solid #f0f0f0;">
                        <div style="width:44px; height:44px; background:#e8eaf6; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-phone" style="color:#3949ab; font-size:18px;"></span>
                        </div>
                        <div style="margin-left:16px;">
                            <div style="color:#9e9e9e; font-size:12px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.Telefono)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:500; margin-top:2px;">
                                @Html.DisplayFor(model => model.Telefono)
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; align-items:center; padding:16px 0;
                                 border-bottom:1px solid #f0f0f0;">
                        <div style="width:44px; height:44px; background:#e8eaf6; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-envelope" style="color:#3949ab; font-size:18px;"></span>
                        </div>
                        <div style="margin-left:16px;">
                            <div style="color:#9e9e9e; font-size:12px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.Correo)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:500; margin-top:2px;">
                                @Html.DisplayFor(model => model.Correo)
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; align-items:center; padding:16px 0;">
                        <div style="width:44px; height:44px; background:#e8eaf6; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-calendar" style="color:#3949ab; font-size:18px;"></span>
                        </div>
                        <div style="margin-left:16px;">
                            <div style="color:#9e9e9e; font-size:12px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.FechaRegistro)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:500; margin-top:2px;">
                                @Html.DisplayFor(model => model.FechaRegistro)
                            </div>
                        </div>
                    </div>

                </div>

                <div style="padding:0 32px 28px;">
                    <hr style="border-color:#e8eaf6; margin-bottom:20px;">
                    <div class="row">
                        <div class="col-sm-4">
                            <a href="@Url.Action("datosalumnos","Alumnos")"
                               class="btn btn-default btn-block"
                               style="border-radius:6px; border-color:#c5cae9; color:#555; padding:10px;">
                                <span class="glyphicon glyphicon-arrow-left" style="margin-right:6px;"></span>
                                Regresar
                            </a>
                        </div>
                        <div class="col-sm-4">
                            <a href="@Url.Action("Edit","Alumnos", new { id = Model.id })"
                               class="btn btn-block"
                               style="background:#fff8e1; color:#f57f17; border:1px solid #ffe082;
                                      border-radius:6px; padding:10px; font-weight:600;">
                                <span class="glyphicon glyphicon-pencil" style="margin-right:6px;"></span>
                                Editar
                            </a>
                        </div>
                        <div class="col-sm-4">
                            <a href="@Url.Action("Delete","Alumnos", new { id = Model.id })"
                               class="btn btn-block"
                               style="background:#ffebee; color:#c62828; border:1px solid #ef9a9a;
                                      border-radius:6px; padding:10px; font-weight:600;">
                                <span class="glyphicon glyphicon-trash" style="margin-right:6px;"></span>
                                Eliminar
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #ffffff;
    }
</style>
