@model UNACH.Alumnos.Sitio100019241.Models.Alumno

@{
    ViewBag.Title = "Editar Alumno";
}

<div class="container" style="padding: 30px 15px;">

    <ol class="breadcrumb"
        style="background:#fff8e1; border-radius:6px; padding:10px 18px;
               margin-bottom:24px; font-size:13px; border-left:4px solid #fdd835;">
        <li class="active" style="color:#555;">Editar Alumno</li>
    </ol>

    <div class="row">
        <div class="col-md-8 col-md-offset-2">

            <div style="background:#fff; border-radius:10px;
                        box-shadow:0 2px 20px rgba(0,0,0,0.1); overflow:hidden;">

                <div style="background: linear-gradient(135deg, #e65100 0%, #f57c00 100%);
                             padding: 22px 28px;">
                    <h3 style="color:#fff; margin:0; font-weight:700;">
                        <span class="glyphicon glyphicon-pencil" style="margin-right:10px;"></span>
                        Editar Información del Alumno
                    </h3>
                    <p style="color:rgba(255,255,255,0.75); margin:6px 0 0; font-size:13px;">
                        Modifique los campos que desea actualizar
                    </p>
                </div>

                <div style="padding:16px 28px; background:#fff8e1; border-bottom:1px solid #ffe082;">
                    <span style="color:#f57f17; font-weight:600; font-size:14px;">
                        <span class="glyphicon glyphicon-tag" style="margin-right:6px;"></span>
                        Editando registro ID: #@Model.id &mdash; @Model.Nombre
                    </span>
                </div>

                <div style="padding:30px 32px;">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger", style = "border-radius:6px;" })
                        @Html.HiddenFor(model => model.id)

                        <div class="form-group" style="margin-bottom:22px;">
                            @Html.LabelFor(model => model.Nombre,
                                htmlAttributes: new
                                     {
                                    @class = "control-label",
                                    style = "color:#e65100; font-weight:600; font-size:14px;"
                                })
                            <div class="input-group">
                                <span class="input-group-addon"
                                      style="background:#fff8e1; border-color:#ffe082; color:#f57f17;">
                                    <span class="glyphicon glyphicon-user"></span>
                                </span>
                                @Html.EditorFor(model => model.Nombre,
                                    new
                                         {
                                             htmlAttributes = new
                                             {
                                        @class = "form-control",
                                        style = "border-color:#ffe082; border-radius:0 4px 4px 0;"
                                    }})
                            </div>
                            @Html.ValidationMessageFor(model => model.Nombre, "",
                                new { @class = "text-danger", style = "font-size:12px;" })
                        </div>

                        <div class="form-group" style="margin-bottom:22px;">
                            @Html.LabelFor(model => model.Telefono,
                                htmlAttributes: new
                                     {
                                    @class = "control-label",
                                    style = "color:#e65100; font-weight:600; font-size:14px;"
                                })
                            <div class="input-group">
                                <span class="input-group-addon"
                                      style="background:#fff8e1; border-color:#ffe082; color:#f57f17;">
                                    <span class="glyphicon glyphicon-phone"></span>
                                </span>
                                @Html.EditorFor(model => model.Telefono,
                                    new
                                         {
                                             htmlAttributes = new
                                             {
                                        @class = "form-control",
                                        style = "border-color:#ffe082; border-radius:0 4px 4px 0;"
                                    }})
                            </div>
                            @Html.ValidationMessageFor(model => model.Telefono, "",
                                new { @class = "text-danger", style = "font-size:12px;" })
                        </div>

                        <div class="form-group" style="margin-bottom:22px;">
                            @Html.LabelFor(model => model.Correo,
                                htmlAttributes: new
                                     {
                                    @class = "control-label",
                                    style = "color:#e65100; font-weight:600; font-size:14px;"
                                })
                            <div class="input-group">
                                <span class="input-group-addon"
                                      style="background:#fff8e1; border-color:#ffe082; color:#f57f17;">
                                    <span class="glyphicon glyphicon-envelope"></span>
                                </span>
                                @Html.EditorFor(model => model.Correo,
                                    new
                                         {
                                             htmlAttributes = new
                                             {
                                        @class = "form-control",
                                        style = "border-color:#ffe082; border-radius:0 4px 4px 0;"
                                    }})
                            </div>
                            @Html.ValidationMessageFor(model => model.Correo, "",
                                new { @class = "text-danger", style = "font-size:12px;" })
                        </div>

                        <div class="form-group" style="margin-bottom:30px;">
                            @Html.LabelFor(model => model.FechaRegistro,
                                htmlAttributes: new
                                     {
                                    @class = "control-label",
                                    style = "color:#9e9e9e; font-weight:600; font-size:14px;"
                                })
                            <div class="input-group">
                                <span class="input-group-addon"
                                      style="background:#f5f5f5; border-color:#e0e0e0; color:#9e9e9e;">
                                    <span class="glyphicon glyphicon-calendar"></span>
                                </span>
                                @Html.EditorFor(model => model.FechaRegistro,
                                    new
                                         {
                                             htmlAttributes = new
                                             {
                                        @class = "form-control",
                                        @readonly = "readonly",
                                        style = "border-color:#e0e0e0; background:#f9f9f9; color:#9e9e9e; border-radius:0 4px 4px 0;"
                                    }})
                            </div>
                            <small style="color:#bdbdbd;">
                                <span class="glyphicon glyphicon-lock" style="margin-right:4px;"></span>
                                Este campo no puede modificarse
                            </small>
                        </div>

                        <hr style="border-color:#ffe082; margin-bottom:24px;">

                        <div class="row">
                            <div class="col-sm-6">
                                <a href="@Url.Action("datosalumnos","Alumnos")"
                                   class="btn btn-default btn-block"
                                   style="border-radius:6px; border-color:#ffe082; color:#555; padding:10px;">
                                    <span class="glyphicon glyphicon-remove" style="margin-right:6px;"></span>
                                    Cancelar
                                </a>
                            </div>
                            <div class="col-sm-6">
                                <button type="submit" class="btn btn-block"
                                        style="background:linear-gradient(135deg,#e65100,#f57c00);
                                               color:#fff; border:none; border-radius:6px;
                                               padding:10px; font-weight:600;
                                               box-shadow:0 3px 10px rgba(230,81,0,0.4);">
                                    <span class="glyphicon glyphicon-floppy-disk" style="margin-right:6px;"></span>
                                    Guardar Cambios
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    body {
        background-color: #ffffff;
    }

    .form-control:focus {
        border-color: #ffb300 !important;
        box-shadow: 0 0 0 3px rgba(255,179,0,0.2) !important;
    }
</style>
