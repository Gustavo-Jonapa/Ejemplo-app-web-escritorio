@model UNACH.Alumnos.Sitio100019241.Models.Alumno

@{
    ViewBag.Title = "Nuevo Alumno";
}

<div class="container" style="padding: 30px 15px;">
    <ol class="breadcrumb"
        style="background:#e8eaf6; border-radius:6px; padding:10px 18px;">
        <li class="active" style="color:#555;">Nuevo Alumno</li>
    </ol>

    <div class="row">
        <div class="col-md-8 col-md-offset-2">
            <div style="background:#fff; border-radius:10px;
                        box-shadow:0 2px 20px rgba(0,0,0,0.1); overflow:hidden;">
                <div style="background: linear-gradient(135deg, #1a237e 0%, #3949ab 100%);
                             padding: 22px 28px;">
                    <h3 style="color:#fff; margin:0; font-weight:700;">
                        <span class="glyphicon glyphicon-user-add"
                              style="margin-right:10px;"></span>
                        Registrar Nuevo Alumno
                    </h3>
                    <p style="color:rgba(255,255,255,0.7); margin:6px 0 0; font-size:13px;">
                        Complete todos los campos requeridos
                    </p>
                </div>
                <div style="padding:30px 32px;">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger", style = "border-radius:6px;" })
                        <div class="form-group" style="margin-bottom:22px;">
                            @Html.LabelFor(model => model.Nombre,
                                htmlAttributes: new
                                     {
                                    @class = "control-label",
                                    style = "color:#1a237e; font-weight:600; font-size:14px;"
                                })
                            <div class="input-group">
                                <span class="input-group-addon"
                                      style="background:#e8eaf6; border-color:#c5cae9; color:#3949ab;">
                                    <span class="glyphicon glyphicon-user"></span>
                                </span>
                                @Html.EditorFor(model => model.Nombre,
                                    new
                                         {
                                             htmlAttributes = new
                                             {
                                        @class = "form-control",
                                        placeholder = "Nombre completo del alumno",
                                        style = "border-color:#c5cae9; border-radius:0 4px 4px 0;"
                                    }})
                            </div>
                            @Html.ValidationMessageFor(model => model.Nombre, "",
                                new { @class = "text-danger", style = "font-size:12px;" })
                        </div>
                        <div class="form-group" style="margin-bottom:22px;">
                            @Html.LabelFor(model => model.Telefono,
                                htmlAttributes: new
                                     {
                                    @class = "control-label",
                                    style = "color:#1a237e; font-weight:600; font-size:14px;"
                                })
                            <div class="input-group">
                                <span class="input-group-addon"
                                      style="background:#e8eaf6; border-color:#c5cae9; color:#3949ab;">
                                    <span class="glyphicon glyphicon-phone"></span>
                                </span>
                                @Html.EditorFor(model => model.Telefono,
                                    new
                                         {
                                             htmlAttributes = new
                                             {
                                        @class = "form-control",
                                        placeholder = "Número de teléfono",
                                        style = "border-color:#c5cae9; border-radius:0 4px 4px 0;"
                                    }})
                            </div>
                            @Html.ValidationMessageFor(model => model.Telefono, "",
                                new { @class = "text-danger", style = "font-size:12px;" })
                        </div>
                        <div class="form-group" style="margin-bottom:30px;">
                            @Html.LabelFor(model => model.Correo,
                                htmlAttributes: new
                                     {
                                    @class = "control-label",
                                    style = "color:#1a237e; font-weight:600; font-size:14px;"
                                })
                            <div class="input-group">
                                <span class="input-group-addon"
                                      style="background:#e8eaf6; border-color:#c5cae9; color:#3949ab;">
                                    <span class="glyphicon glyphicon-envelope"></span>
                                </span>
                                @Html.EditorFor(model => model.Correo,
                                    new
                                         {
                                             htmlAttributes = new
                                             {
                                        @class = "form-control",
                                        placeholder = "correo@ejemplo.com",
                                        style = "border-color:#c5cae9; border-radius:0 4px 4px 0;"
                                    }})
                            </div>
                            @Html.ValidationMessageFor(model => model.Correo, "",
                                new { @class = "text-danger", style = "font-size:12px;" })
                        </div>
                        <hr style="border-color:#e8eaf6; margin-bottom:24px;">

                        <div class="row">
                            <div class="col-sm-6">
                                <a href="@Url.Action("datosalumnos","Alumnos")"
                                   class="btn btn-default btn-block"
                                   style="border-radius:6px; border-color:#c5cae9; color:#555; padding:10px;">
                                    <span class="glyphicon glyphicon-arrow-left"
                                          style="margin-right:6px;"></span>
                                    Cancelar
                                </a>
                            </div>
                            <div class="col-sm-6">
                                <button type="submit" class="btn btn-block"
                                        style="background:linear-gradient(135deg,#1a237e,#3949ab);
                                               color:#fff; border:none; border-radius:6px;
                                               padding:10px; font-weight:600;
                                               box-shadow:0 3px 10px rgba(57,73,171,0.4);">
                                    <span class="glyphicon glyphicon-floppy-disk"
                                          style="margin-right:6px;"></span>
                                    Guardar Alumno
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    body {
        background-color: #f0f2ff;
    }

    .form-control:focus {
        border-color: #7986cb !important;
        box-shadow: 0 0 0 3px rgba(121,134,203,0.2) !important;
    }
</style>
