@model UNACH.Alumnos.Sitio100019241.Models.Alumno

@{
    ViewBag.Title = "Eliminar Alumno";
}

<div class="container" style="padding: 30px 15px;">

    <ol class="breadcrumb"
        style="background:#ffebee; border-radius:6px; padding:10px 18px;
               margin-bottom:24px; font-size:13px; border-left:4px solid #ef5350;">
        <li class="active" style="color:#555;">Eliminar Alumno</li>
    </ol>

    <div class="row">
        <div class="col-md-7 col-md-offset-2">

            <div style="background:#fff; border-radius:10px;
                        box-shadow:0 2px 20px rgba(0,0,0,0.1); overflow:hidden;">

                <div style="background: linear-gradient(135deg, #b71c1c 0%, #e53935 100%);
                             padding: 22px 28px;">
                    <h3 style="color:#fff; margin:0; font-weight:700;">
                        <span class="glyphicon glyphicon-warning-sign" style="margin-right:10px;"></span>
                        Confirmar Eliminación
                    </h3>
                    <p style="color:rgba(255,255,255,0.75); margin:6px 0 0; font-size:13px;">
                        Esta acción no se puede deshacer
                    </p>
                </div>

                <div style="background:#fff3e0; padding:16px 28px; border-bottom:1px solid #ffe0b2;">
                    <p style="margin:0; color:#e65100; font-weight:600; font-size:14px;">
                        <span class="glyphicon glyphicon-exclamation-sign" style="margin-right:8px;"></span>
                        ¿Está seguro de que desea eliminar este registro permanentemente?
                    </p>
                </div>

                <div style="padding:28px 32px;">

                    <h5 style="color:#9e9e9e; text-transform:uppercase; font-size:11px;
                               letter-spacing:1px; font-weight:700; margin-bottom:16px;">
                        Información del alumno a eliminar
                    </h5>

                    <div style="display:flex; align-items:center; padding:14px 0;
                                 border-bottom:1px solid #f0f0f0;">
                        <div style="width:40px; height:40px; background:#ffebee; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-user" style="color:#e53935; font-size:16px;"></span>
                        </div>
                        <div style="margin-left:14px;">
                            <div style="color:#bdbdbd; font-size:11px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.Nombre)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:600; margin-top:2px;">
                                @Html.DisplayFor(model => model.Nombre)
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; align-items:center; padding:14px 0;
                                 border-bottom:1px solid #f0f0f0;">
                        <div style="width:40px; height:40px; background:#ffebee; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-phone" style="color:#e53935; font-size:16px;"></span>
                        </div>
                        <div style="margin-left:14px;">
                            <div style="color:#bdbdbd; font-size:11px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.Telefono)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:500; margin-top:2px;">
                                @Html.DisplayFor(model => model.Telefono)
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; align-items:center; padding:14px 0;
                                 border-bottom:1px solid #f0f0f0;">
                        <div style="width:40px; height:40px; background:#ffebee; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-envelope" style="color:#e53935; font-size:16px;"></span>
                        </div>
                        <div style="margin-left:14px;">
                            <div style="color:#bdbdbd; font-size:11px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.Correo)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:500; margin-top:2px;">
                                @Html.DisplayFor(model => model.Correo)
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; align-items:center; padding:14px 0;">
                        <div style="width:40px; height:40px; background:#ffebee; border-radius:8px;
                                    display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <span class="glyphicon glyphicon-calendar" style="color:#e53935; font-size:16px;"></span>
                        </div>
                        <div style="margin-left:14px;">
                            <div style="color:#bdbdbd; font-size:11px; font-weight:600;
                                        text-transform:uppercase; letter-spacing:0.5px;">
                                @Html.DisplayNameFor(model => model.FechaRegistro)
                            </div>
                            <div style="color:#333; font-size:15px; font-weight:500; margin-top:2px;">
                                @Html.DisplayFor(model => model.FechaRegistro)
                            </div>
                        </div>
                    </div>

                </div>

                <div style="padding:0 32px 28px;">
                    <hr style="border-color:#ffcdd2; margin-bottom:20px;">

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="col-sm-6">
                                <a href="@Url.Action("datosalumnos","Alumnos")"
                                   class="btn btn-default btn-block"
                                   style="border-radius:6px; border-color:#e0e0e0; color:#555; padding:11px; font-weight:600;">
                                    <span class="glyphicon glyphicon-ban-circle" style="margin-right:6px;"></span>
                                    No, Cancelar
                                </a>
                            </div>
                            <div class="col-sm-6">
                                <button type="submit" class="btn btn-block"
                                        style="background:linear-gradient(135deg,#b71c1c,#e53935);
                                               color:#fff; border:none; border-radius:6px;
                                               padding:11px; font-weight:700;
                                               box-shadow:0 3px 10px rgba(183,28,28,0.4);">
                                    <span class="glyphicon glyphicon-trash" style="margin-right:6px;"></span>
                                    Sí, Eliminar
                                </button>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #ffffff;
    }
</style>
